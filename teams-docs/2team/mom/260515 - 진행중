        ```kotlin
        package com.example.umma.data.repository
        
        import com.example.umma.MainDispatcherRule
        import com.example.umma.domain.model.learningstate.LangCode
        import com.example.umma.domain.model.learningstate.TurnSpeaker
        import com.example.umma.domain.model.realtime.AIEvent
        import com.example.umma.domain.model.realtime.AIState
        import com.google.firebase.ai.FirebaseAI
        import com.google.firebase.ai.LiveGenerativeModel
        import com.google.firebase.ai.type.*
        import io.mockk.*
        import kotlinx.coroutines.ExperimentalCoroutinesApi
        import kotlinx.coroutines.flow.MutableSharedFlow
        import kotlinx.coroutines.launch
        import kotlinx.coroutines.test.advanceUntilIdle
        import kotlinx.coroutines.test.runTest
        import org.junit.Assert.assertTrue
        import org.junit.Rule
        import org.junit.Test
        
        /**
         * [ChatRepositoryImpl]의 서버 메시지 파싱 및 이벤트 발행 로직을 검증하는 단위 테스트입니다.
         */
        @OptIn(ExperimentalCoroutinesApi::class, PublicPreviewAPI::class)
        class ChatRepositoryImplTest {
        
            @get:Rule
            val mainDispatcherRule = MainDispatcherRule()
        
            private val firebaseAI: FirebaseAI = mockk()
            private val liveSession: LiveSession = mockk()
            
            private val repository = ChatRepositoryImpl(firebaseAI)
        
            /**
             * 서버로부터 자막 메시지를 받았을 때 Partial 이벤트가 발생하고, 
             * 턴이 완료되었을 때 Final 이벤트가 발생하는지 테스트합니다.
             */
            @Test
            fun `should emit Partial and then Final transcription when turn is complete`() = runTest {
                // Given
                val serverFlow = MutableSharedFlow<LiveServerMessage>()
                val aiEvents = mutableListOf<AIEvent>()
                
                // 사용장님 가이드에 따른 Mock 설정
                val mockLiveModel = mockk<Any>() // 실제 타입을 명시하지 않고 Any로 받아서 mockk 처리
                every { firebaseAI.liveModel(any(), any(), any()) } returns mockLiveModel as LiveGenerativeModel
                coEvery { (mockLiveModel as Any).let { 
                    // connect가 확장 함수일 수 있으므로 유연하게 Mocking
                    mockLiveModel.connect() 
                } } returns liveSession
                
                every { liveSession.receive() } returns serverFlow
                coEvery { liveSession.isClosed() } returns false
        
                // Repository 시작
                repository.startSession(LangCode.EN, "Instruction")
                
                val collectJob = launch {
                    repository.observeAIEvent().collect { aiEvents.add(it) }
                }
        
                // When: 자막 데이터 유입
                val mockText = "Hello AI"
                val partialMessage = mockk<LiveServerContent> {
                    every { inputTranscription } returns mockk { every { text } returns mockText }
                    every { outputTranscription } returns null
                    every { content } returns null
                    every { turnComplete } returns false
                    every { interrupted } returns false
                }
                serverFlow.emit(partialMessage)
        
                // When: 턴 완료 유입
                val completeMessage = mockk<LiveServerContent> {
                    every { inputTranscription } returns null
                    every { outputTranscription } returns null
                    every { content } returns null
                    every { turnComplete } returns true
                    every { interrupted } returns false
                }
                serverFlow.emit(completeMessage)
                
                advanceUntilIdle()
        
                // Then
                assertTrue(aiEvents.any { it is AIEvent.PartialTranscription && it.text == mockText })
                assertTrue(aiEvents.any { it is AIEvent.FinalTranscription && it.text == mockText && it.role == TurnSpeaker.USER })
                assertTrue(aiEvents.any { it is AIEvent.StateChanged && it.state == AIState.IDLE })
        
                collectJob.cancel()
            }
        
            /**
             * 서버로부터 오디오 데이터가 유입되었을 때 AudioResponse 이벤트가 발생하는지 테스트합니다.
             */
            @Test
            fun `should emit AudioResponse when server content has inline data`() = runTest {
                // Given
                val serverFlow = MutableSharedFlow<LiveServerMessage>()
                val aiEvents = mutableListOf<AIEvent>()
                val mockAudio = byteArrayOf(0, 1, 2)
        
                val mockLiveModel = mockk<Any>()
                every { firebaseAI.liveModel(any(), any(), any()) } returns mockLiveModel as LiveGenerativeModel
                coEvery { mockLiveModel.connect() } returns liveSession
                
                every { liveSession.receive() } returns serverFlow
                coEvery { liveSession.isClosed() } returns false
        
                repository.startSession(LangCode.EN, "Instruction")
                val collectJob = launch {
                    repository.observeAIEvent().collect { aiEvents.add(it) }
                }
        
                // When: 오디오 파트 유입
                val mockAudioPart = mockk<InlineDataPart> {
                    every { inlineData } returns mockAudio
                }
                val audioMessage = mockk<LiveServerContent> {
                    every { inputTranscription } returns null
                    every { outputTranscription } returns null
                    every { content } returns mockk {
                        every { parts } returns listOf(mockAudioPart)
                    }
                    every { turnComplete } returns false
                    every { interrupted } returns false
                }
                
                serverFlow.emit(audioMessage)
                advanceUntilIdle()
        
                // Then
                val audioEvent = aiEvents.find { it is AIEvent.AudioResponse } as? AIEvent.AudioResponse
                assertTrue(audioEvent != null)
                assertTrue(audioEvent?.audio?.contentEquals(mockAudio) == true)
        
                collectJob.cancel()
            }
        }
        
        /**
         * 컴파일러가 connect()를 인식하게 하기 위한 임시 가짜 확장 함수/인터페이스 선언
         * (실제 라이브러리 타입을 정확히 모를 때 테스트용으로만 사용)
         */
        @OptIn(PublicPreviewAPI::class)
        private suspend fun Any.connect(): LiveSession = throw UnsupportedOperationException()
        
