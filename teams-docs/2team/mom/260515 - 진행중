        ```kotlin
        package com.example.umma.presentation.chat
        
        import com.example.umma.MainDispatcherRule
        import com.example.umma.data.source.local.AudioPlayer
        import com.example.umma.data.source.local.AudioRecorder
        import com.example.umma.domain.model.learningstate.TurnSpeaker
        import com.example.umma.domain.model.realtime.AIEvent
        import com.example.umma.domain.usecase.chat.ObserveAIEventUseCase
        import com.example.umma.domain.usecase.chat.SendAudioDataUseCase
        import com.example.umma.domain.usecase.chat.StartSessionUseCase
        import com.example.umma.domain.usecase.chat.StopSessionUseCase
        import io.mockk.*
        import kotlinx.coroutines.ExperimentalCoroutinesApi
        import kotlinx.coroutines.flow.MutableSharedFlow
        import kotlinx.coroutines.test.advanceUntilIdle
        import kotlinx.coroutines.test.runTest
        import org.junit.Assert.assertEquals
        import org.junit.Assert.assertTrue
        import org.junit.Rule
        import org.junit.Test
        
        /**
         * [ChatViewModel]의 UI 상태 관리 및 이벤트 반응 로직을 검증하는 단위 테스트입니다.
         */
        @OptIn(ExperimentalCoroutinesApi::class)
        class ChatViewModelTest {
        
            @get:Rule
            val mainDispatcherRule = MainDispatcherRule()
        
            private val startSessionUseCase: StartSessionUseCase = mockk()
            private val observeAIEventUseCase: ObserveAIEventUseCase = mockk()
            private val sendAudioDataUseCase: SendAudioDataUseCase = mockk()
            private val stopSessionUseCase: StopSessionUseCase = mockk()
            private val audioRecorder: AudioRecorder = mockk()
            private val audioPlayer: AudioPlayer = mockk()
        
            /**
             * 의존성들이 주입된 ViewModel을 생성합니다.
             */
            private fun createViewModel() = ChatViewModel(
                startSessionUseCase = startSessionUseCase,
                observeAIEventUseCase = observeAIEventUseCase,
                sendAudioDataUseCase = sendAudioDataUseCase,
                stopSessionUseCase = stopSessionUseCase,
                audioRecorder = audioRecorder,
                audioPlayer = audioPlayer
            )
        
            /**
             * 초기 상태가 IDLE이고 데이터가 비어 있는지 확인합니다.
             */
            @Test
            fun `initial state should be IDLE and empty`() {
                val viewModel = createViewModel()
                val state = viewModel.uiState.value
        
                assertEquals(SessionState.IDLE, state.sessionState)
                assertTrue(state.lastTranscription.isEmpty())
            }
        
            /**
             * 대화 시작 시 세션이 성공적으로 열리면 READY 상태로 전이되는지 테스트합니다.
             */
            @Test
            fun `startChat should transition from LOADING to READY on success`() = runTest {
                // Given
                val aiEventFlow = MutableSharedFlow<AIEvent>()
                val expectedSessionId = "session_123"
                coEvery { startSessionUseCase() } returns Result.success(expectedSessionId)
                every { observeAIEventUseCase() } returns aiEventFlow
                every { audioRecorder.startRecording() } returns MutableSharedFlow() // Recorder mock
        
                val viewModel = createViewModel()
        
                // When
                viewModel.startChat()
                
                // Initialized 이벤트 발생 시뮬레이션
                aiEventFlow.emit(AIEvent.Initialized(expectedSessionId))
                advanceUntilIdle()
        
                // Then
                assertEquals(SessionState.READY, viewModel.uiState.value.sessionState)
                assertEquals(expectedSessionId, viewModel.uiState.value.activeSessionId)
            }
        
            /**
             * 실시간 자막 이벤트가 수신되었을 때 UI 상태가 업데이트되는지 테스트합니다.
             */
            @Test
            fun `uiState should update lastTranscription when PartialTranscription event occurs`() = runTest {
                // Given
                val aiEventFlow = MutableSharedFlow<AIEvent>()
                coEvery { startSessionUseCase() } returns Result.success("session_123")
                every { observeAIEventUseCase() } returns aiEventFlow
                every { audioRecorder.startRecording() } returns MutableSharedFlow()
        
                val viewModel = createViewModel()
                viewModel.startChat()
                aiEventFlow.emit(AIEvent.Initialized("session_123"))
        
                // When
                val mockTranscription = "Hello, how are you?"
                aiEventFlow.emit(AIEvent.PartialTranscription(mockTranscription, TurnSpeaker.AI))
                advanceUntilIdle()
        
                // Then
                assertEquals(mockTranscription, viewModel.uiState.value.lastTranscription)
            }
        
            /**
             * 에러 이벤트 발생 시 세션이 중단되고 ERROR 상태로 전이되는지 테스트합니다.
             */
            @Test
            fun `session should transition to ERROR when AIEvent Error occurs`() = runTest {
                // Given
                val aiEventFlow = MutableSharedFlow<AIEvent>()
                coEvery { startSessionUseCase() } returns Result.success("session_123")
                every { observeAIEventUseCase() } returns aiEventFlow
                every { audioRecorder.startRecording() } returns MutableSharedFlow()
                coEvery { stopSessionUseCase() } just Runs
                every { audioPlayer.stopPlaying() } just Runs
        
                val viewModel = createViewModel()
                viewModel.startChat()
                aiEventFlow.emit(AIEvent.Initialized("session_123"))
        
                // When
                val errorMsg = "Network Failure"
                aiEventFlow.emit(AIEvent.Error(errorMsg))
                advanceUntilIdle()
        
                // Then
                assertEquals(SessionState.ERROR, viewModel.uiState.value.sessionState)
                assertEquals(errorMsg, viewModel.uiState.value.errorMessage)
            }
        }
        
