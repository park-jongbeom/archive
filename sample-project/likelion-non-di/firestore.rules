// Firestore 보안 규칙 (로그인 사용자만 chatrooms/messages/events 접근)
// 배포: Firebase Console → Firestore → 규칙 탭에서 이 내용 붙여넣기 후 게시
// 또는 Firebase CLI: firebase deploy --only firestore
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 로그인한 사용자만 채팅방 목록/생성/수정/삭제 가능
    match /chatrooms/{roomId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
      match /events/{eventId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
